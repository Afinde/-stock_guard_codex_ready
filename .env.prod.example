APP_ENV=prod
APP_VERSION=0.1.0
DEPLOYMENT_PROFILE=ECS_LITE
API_PREFIX=/api/v1
POSTGRES_PASSWORD=change-this-database-password
DATABASE_URL=postgresql+psycopg://stock_guard:change-this-database-password@postgres:5432/stock_guard
ENABLE_SERVER_BACKTEST=false
ENABLE_LIGHT_SCAN=true
ENABLE_PAPER_ORDER_WRITE=false
ENABLE_LIVE_PROVIDER=false
ENABLE_LIVE_ORDER=false
ENABLE_WEBSOCKET=false
MAX_PAGE_SIZE=100
DASHBOARD_CACHE_SECONDS=30
AUTH_REQUIRED=true
AUTH_JWT_SECRET=change-this-to-a-random-64-character-secret-before-deploy
AUTH_ACCESS_TOKEN_MINUTES=30
AUTH_REFRESH_TOKEN_DAYS=7
AUTH_COOKIE_SECURE=true
AUTH_LOGIN_FAILURE_LIMIT=5
AUTH_LOCKOUT_MINUTES=15
MARKET_DATA_MODE=FIXTURE
MARKET_LIVE_PROVIDER=fixture
MARKET_LIVE_ENABLED=false
MANUAL_CONFIRM_REQUIRED=true

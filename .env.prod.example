APP_ENV=prod
APP_VERSION=0.1.0
DEPLOYMENT_PROFILE=ECS_LITE
API_PREFIX=/api/v1
DATABASE_URL=sqlite:////app/data/stock_guard.db
ENABLE_SERVER_BACKTEST=false
ENABLE_LIGHT_SCAN=true
ENABLE_PAPER_ORDER_WRITE=false
ENABLE_LIVE_PROVIDER=false
ENABLE_LIVE_ORDER=false
ENABLE_WEBSOCKET=false
MAX_PAGE_SIZE=100
DASHBOARD_CACHE_SECONDS=30
MARKET_DATA_MODE=FIXTURE
MARKET_LIVE_PROVIDER=fixture
MARKET_LIVE_ENABLED=false
MANUAL_CONFIRM_REQUIRED=true
